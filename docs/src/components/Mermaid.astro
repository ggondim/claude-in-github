---
interface Props {
  chart: string;
}
const { chart } = Astro.props;
---

<div class="mermaid-wrap not-content">
  <pre class="mermaid">{chart}</pre>
</div>

<style>
  .mermaid-wrap {
    margin: 1.5rem 0;
    overflow-x: auto;
  }
  .mermaid-wrap pre {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }
</style>
